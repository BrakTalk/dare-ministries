---
layout: false
---
{% from "icons.njk" import icon %}
{% from "head.njk" import head %}
<!DOCTYPE html>
<html lang="en">
<head>
  {{ head(site.title + " — Disaster Assistance and Relief Effort", site.description) }}
</head>
<body>

  {% include "navbar.njk" %}

  <!-- Hero Section -->
  <section class="hero" id="home">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <img src="/images/luke-5-cartoon.jpg" alt="Three-panel comic: Luke 5:17-26 — the roof is opened, a tarp is placed, then D.A.R.E. arrives to fix it properly. 'But who fixed the roof?'" class="hero-image" loading="lazy">
      <h1>{{ site.tagline }}</h1>
      <p class="hero-subtitle">{{ site.subtitle }}</p>
      <p class="hero-text">{{ site.description }}</p>
      <div class="hero-buttons">
        <a href="#volunteer" class="btn btn-primary">Join a Team</a>
        <a href="#about" class="btn btn-outline">Our Mission</a>
      </div>
    </div>
  </section>

  <!-- Mission Stats Bar -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat">
        <span class="stat-number">Long-Term</span>
        <span class="stat-label">Recovery Commitment</span>
      </div>
      <div class="stat">
        <span class="stat-number">All Welcome</span>
        <span class="stat-label">No Skills Required</span>
      </div>
      <div class="stat">
        <span class="stat-number">$0</span>
        <span class="stat-label">Cost to Volunteer</span>
      </div>
      <div class="stat">
        <span class="stat-number">Georgia</span>
        <span class="stat-label">Communities Served</span>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section about" id="about">
    <div class="container">
      <div class="section-header">
        <h2>Our Mission</h2>
        <div class="section-divider"></div>
      </div>
      <div class="about-grid">
        <div class="about-text">
          <h3>{{ site.about.heading }}</h3>
          {% for paragraph in site.about.paragraphs %}
          <p>{{ paragraph | safe }}</p>
          {% endfor %}
          <blockquote>
            <p>"{{ site.scripture }}"</p>
          </blockquote>
        </div>
        <div class="about-image">
          <img src="/images/dare-logo.png" alt="D.A.R.E. to CARE — Disaster Assistance and Relief Effort" class="about-logo">
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do Section -->
  <section class="section what-we-do">
    <div class="container">
      <div class="section-header">
        <h2>What We Do</h2>
        <div class="section-divider"></div>
      </div>
      <div class="services-grid">
        {% for service in site.services %}
        <div class="service-card">
          <div class="service-icon">
            {{ icon(service.icon) }}
          </div>
          <h3>{{ service.title }}</h3>
          <p>{{ service.description }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Our Story / History Section -->
  <section class="section history" id="history">
    <div class="container">
      <div class="section-header">
        <h2>{{ site.history.heading }}</h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">{{ site.history.subtitle }}</p>
      </div>
      <div class="history-comic">
      </div>
      <div class="timeline">
        {% for milestone in site.history.milestones %}
        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-year">{{ milestone.year }}</span>
          </div>
          <div class="timeline-card">
            <h3>{{ milestone.title }}</h3>
            <p>{{ milestone.body }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
      {% if site.history.closing %}
      <div class="history-closing">
        <p>{{ site.history.closing }}</p>
      </div>
      {% endif %}
    </div>
  </section>

  <!-- Impact Counter Section -->
  <section class="impact-counter" id="impact">
    <div class="container">
      <div class="section-header">
        <h2>Our Impact</h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Twenty years of showing up — here's what that looks like in numbers.</p>
      </div>
      <div class="impact-grid">
        <div class="impact-stat">
          <span class="impact-number" id="stat-homes">—</span>
          <span class="impact-label">Homes Repaired</span>
        </div>
        <div class="impact-stat">
          <span class="impact-number" id="stat-families">—</span>
          <span class="impact-label">Families Helped</span>
        </div>
        <div class="impact-stat">
          <span class="impact-number" id="stat-deployments">—</span>
          <span class="impact-label">Deployments</span>
        </div>
        <div class="impact-stat">
          <span class="impact-number" id="stat-hours">—</span>
          <span class="impact-label">Volunteer Hours</span>
        </div>
        <div class="impact-stat">
          <span class="impact-number" id="stat-partners">—</span>
          <span class="impact-label">Partner Organizations</span>
        </div>
        <div class="impact-stat">
          <span class="impact-number" id="stat-years">—</span>
          <span class="impact-label">Years of Service</span>
        </div>
      </div>
      <p class="impact-note">Numbers updated by DARE leadership. Last updated: <span id="impact-updated">—</span></p>
    </div>
  </section>

  <!-- Current Projects Section -->
  <section class="section projects" id="projects">
    <div class="container">
      <div class="section-header">
        <h2>Current Projects</h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Where we're working right now</p>
      </div>
      <div class="projects-grid">
        {% for project in projects.items %}
        <div class="project-card">
          <div class="project-location">
            {{ icon("map-pin", 20) }}
            {{ project.location }}
          </div>
          <h3>{{ project.title }}</h3>
          <p>{{ project.description }}</p>
          <div class="project-status">
            <span class="status-badge {{ project.status }}">{{ project.status | capitalize }}</span>
            {% if project.accepting_volunteers %}
            <span class="project-detail">Accepting volunteers</span>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="projects-cta">
        <p>Know a community that needs help? <a href="#contact">Get in touch</a> and let us know.</p>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section class="section gallery" id="gallery">
    <div class="container">
      <div class="section-header">
        <h2>Our Work</h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Stories of recovery and hope from the field</p>
      </div>
      <div class="gallery-grid">
        {% for item in gallery.items %}
        <div class="gallery-item">
          {% if item.image %}
          <img src="{{ item.image }}" alt="{{ item.alt }}" loading="lazy">
          <span class="gallery-caption">{{ item.caption }}</span>
          {% else %}
          <div class="gallery-placeholder">
            <span>{{ item.caption }}</span>
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      <p class="gallery-note"><em>Have photos from a DARE deployment? Send them to <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a></em></p>
    </div>
  </section>

  <!-- From the Field Section -->
  {% if fieldNotes.length %}
  <section class="section updates" id="updates">
    <div class="container">
      <div class="section-header">
        <h2>From the Field</h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Recaps from our latest deployments</p>
      </div>
      <div class="posts-grid">
        {% for note in fieldNotes.slice(0, 3) %}
        <article class="post-card">
          {% if note.cover %}
          <a href="/field-notes/{{ note.slug }}/" class="post-image">
            <img src="{{ note.cover.url }}" alt="{{ note.cover.alt }}" loading="lazy">
          </a>
          {% endif %}
          <div class="post-content">
            <time class="post-date">{{ note.date_display }}</time>
            <h3><a href="/field-notes/{{ note.slug }}/">{{ note.title }}</a></h3>
            <p>{{ note.body | markdown | striptags | truncate(150) }}</p>
          </div>
        </article>
        {% endfor %}
      </div>
      <div class="projects-cta">
        <a href="/field-notes/" class="btn btn-outline">Read All Field Notes</a>
      </div>
    </div>
  </section>
  {% endif %}

  <!-- Volunteer Section -->
  <section class="section volunteer" id="volunteer">
    <div class="container">
      <div class="section-header">
        <h2>Get Involved</h2>
        <div class="section-divider"></div>
      </div>
      <div class="volunteer-grid">
        <div class="volunteer-info">
          <h3>Join a D.A.R.E. Team</h3>
          <p>There is <strong>no charge</strong> to join a DARE team and <strong>no special skills are required</strong>. Whether you can swing a hammer or have never held one, there is meaningful work for you.</p>
          <div class="volunteer-perks">
            {% set perks = [
              "Free to volunteer — no fees or costs",
              "Overnight lodging provided",
              "Meals provided during deployment",
              "No experience necessary",
              "Church groups & individuals welcome"
            ] %}
            {% for perk in perks %}
            <div class="perk">
              {{ icon("check", 24) }}
              <span>{{ perk }}</span>
            </div>
            {% endfor %}
          </div>
        </div>
        <div class="volunteer-form-container">
          <form class="volunteer-form" id="volunteerForm">
            <h4>Volunteer Interest Form</h4>
            <div class="form-group">
              <label for="name">Full Name *</label>
              <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone">
            </div>
            <div class="form-group">
              <label for="church">Church or Organization</label>
              <input type="text" id="church" name="church" placeholder="e.g., Roswell UMC">
            </div>
            <div class="form-group">
              <label for="skills">Skills or Experience</label>
              <textarea id="skills" name="skills" rows="3" placeholder="Any construction, medical, cooking, or other skills you'd like to share (none required!)"></textarea>
            </div>
            <div class="form-group">
              <label for="availability">Availability</label>
              <select id="availability" name="availability">
                <option value="">Select your availability</option>
                <option value="weekdays">Weekdays</option>
                <option value="weekends">Weekends</option>
                <option value="multi-day">Multi-day deployments (3+ days)</option>
                <option value="flexible">Flexible / Any time</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Anything else we should know?</label>
              <textarea id="message" name="message" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Sign Up to Volunteer</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Donate Section -->
  <section class="section donate" id="donate">
    <div class="donate-overlay"></div>
    <div class="container">
      <div class="donate-content">
        <h2>{{ site.donate.heading }}</h2>
        <p>{{ site.donate.description }}</p>
        <div class="donate-options">
          {% if site.donate.url %}
          <a href="{{ site.donate.url }}" class="btn btn-primary btn-large" target="_blank" rel="noopener">Make a Donation</a>
          {% else %}
          <a href="mailto:{{ site.contact.email }}?subject=Donation%20Inquiry%20-%20DARE%20Ministries" class="btn btn-primary btn-large">Make a Donation</a>
          {% endif %}
        </div>
        <p class="donate-note">{{ site.donate.note }} Contact us at <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a> or call <a href="tel:+17063402221">{{ site.contact.phone }}</a>.</p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section contact" id="contact">
    <div class="container">
      <div class="section-header">
        <h2>Contact Us</h2>
        <div class="section-divider"></div>
      </div>
      <div class="contact-grid">
        <div class="contact-info">
          <h3>Get in Touch</h3>
          <p>Whether you want to volunteer, donate, request assistance, or bring your church group on a deployment, we'd love to hear from you.</p>
          <div class="contact-details">
            <div class="contact-item">
              {{ icon("user", 24) }}
              <div>
                <strong>{{ site.contact.name }}</strong>
                <span>{{ site.contact.title }}</span>
              </div>
            </div>
            <div class="contact-item">
              {{ icon("mail", 24) }}
              <div>
                <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
              </div>
            </div>
            <div class="contact-item">
              {{ icon("phone", 24) }}
              <div>
                <a href="tel:+17063402221">{{ site.contact.phone }}</a>
              </div>
            </div>
            <div class="contact-item">
              {{ icon("map-pin", 24) }}
              <div>
                <span>Serving communities across Georgia</span>
              </div>
            </div>
          </div>
        </div>
        <div class="contact-form-container">
          <form class="contact-form">
            <p style="display:none"><label>Don't fill this out: <input name="bot-field"></label></p>
            <h4>Send Us a Message</h4>
            <div class="form-group">
              <label for="contact-name">Your Name *</label>
              <input type="text" id="contact-name" name="name" required>
            </div>
            <div class="form-group">
              <label for="contact-email">Email Address *</label>
              <input type="email" id="contact-email" name="email" required>
            </div>
            <div class="form-group">
              <label for="contact-subject">Subject</label>
              <select id="contact-subject" name="subject">
                <option value="">What is this about?</option>
                <option value="volunteer">Volunteering</option>
                <option value="donation">Donations</option>
                <option value="assistance">Request Assistance</option>
                <option value="church-group">Church Group Deployment</option>
                <option value="partnership">Partnership Inquiry</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="contact-message">Message *</label>
              <textarea id="contact-message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  {% include "footer.njk" %}

  <script src="/js/main.js"></script>
  <script src="/js/forms.js" defer></script>
</body>
</html>